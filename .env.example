# Database
POSTGRES_USER=srag_app
POSTGRES_PASSWORD=srag_pass
POSTGRES_DB=srag
POSTGRES_PORT=5433

# LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
